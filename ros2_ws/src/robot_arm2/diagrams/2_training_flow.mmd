flowchart TD
    %% Optimized Training Flow for Condensed A4 Layout
    
    Start([Start Step]) --> Observe["Read Joints & Target"]
    
    Observe --> FK["Calculate EE Pos<br>(FK)"]
    FK --> Dist["Compare:<br>Error = |Target - EE|"]
    
    Dist --> Agent{"SAC Agent"}
    
    subgraph Action Selection
        direction TB
        Agent -->|Training| Explore[Sample + Noise]
        Agent -->|Eval| Policy[Policy Net]
    end
    
    Explore & Policy --> NIK[Neural IK Model]
    NIK -->|Predict| Execute[Execute Joint cmd]
    
    Execute --> Step[Physics Step]
    Step --> Reward{Goal Reached?<br>Dist < 1cm}
    
    subgraph Reward Logic
        Reward -->|Yes| Success[Reward = 0]
        Reward -->|No| Penalty[Reward = -1]
    end
    
    Success & Penalty --> Buffer["Save to Buffer"]
    Buffer --> Update[Update Networks]
    
    Update --> Done{Min Steps?}
    Done -->|No| Start
    Done -->|Yes| Finish([Episode End])

    %% Styling
    style Start fill:#90EE90,stroke:#333
    style Finish fill:#FFB6C1,stroke:#333
    style FK fill:#ADD8E6,stroke-width:2px
    style Dist fill:#ADD8E6,stroke-width:2px
    style Agent fill:#FFA07A,stroke-width:2px
    style NIK fill:#DDA0DD,stroke-width:2px
    style Reward fill:#FFD700
