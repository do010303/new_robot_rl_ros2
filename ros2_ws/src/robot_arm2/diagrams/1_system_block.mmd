graph TD
    subgraph "RL Training Node (Python)"
        Trainer[Training Loop]
        Agent[SAC Agent]
        Replay[Replay Buffer]
        Env[RL Environment]
        NIK[Neural IK]
    end

    subgraph "ROS2 Communication Layer"
        TopicCmd[Topic: /joint_commands]
        TopicState[Topic: /joint_states]
        ServiceReset[Service: /reset_simulation]
    end

    subgraph "Simulation / Hardware"
        Gazebo[Gazebo Simulation]
        RealRobot["Real Robot Arm<br>(Raspberry Pi)"]
    end

    %% Connections
    Trainer --> Agent
    Agent <--> Replay
    Trainer --> Env
    
    Env -->|Get State| TopicState
    TopicState -->|Joint Pos| Env
    
    Env -->|Publish Action| TopicCmd
    TopicCmd -->|Trajectory| Gazebo
    TopicCmd -->|PWM Signals| RealRobot
    
    Env -->|Reset| ServiceReset
    ServiceReset --> Gazebo
    
    Agent -->|3D Target| NIK
    NIK -->|Joint Angles| Env
    Environment -->|Reward/Done| Trainer
