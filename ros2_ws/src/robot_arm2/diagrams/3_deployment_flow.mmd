flowchart TD
    %% Simple Linear Deployment Flow
    
    subgraph Workstation
        Model["Trained Model<br>(PyTorch)"] --> Export["Export & Quantize<br>(ONNX)"]
    end
    
    Export -->|Transfer Files| Pi
    
    subgraph "Raspberry Pi"
        Pi["Run RL Node<br>(ONNX Runtime)"] --> Driver[PCA9685 Driver]
    end
    
    Driver --> Servo[Servo Motors]
    
    %% Styling
    style Model fill:#90EE90,stroke:#333
    style Export fill:#ADD8E6,stroke:#333
    style Pi fill:#FFA07A,stroke:#333
    style Driver fill:#DDA0DD,stroke:#333
    style Servo fill:#F0E68C,stroke:#333
