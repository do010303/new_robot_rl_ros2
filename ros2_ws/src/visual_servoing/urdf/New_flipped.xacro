<?xml version="1.0" ?>
<!-- 
  Flipped Robot URDF for Visual Servoing
  - Base at ceiling, pen tip pointing down  
  - Camera at base viewing toward +Y axis
  - Works independently from main RL project
-->
<robot name="robot_arm_flipped" xmlns:xacro="http://www.ros.org/wiki/xacro">

<!-- ==================== MATERIALS ==================== -->
<material name="silver_default">
  <color rgba="0.700 0.700 0.700 1.000"/>
</material>
<material name="steel_satin">
  <color rgba="0.627 0.627 0.627 1.0"/>
</material>

<!-- ==================== WORLD LINK ==================== -->
<link name="world"/>

<!-- World to base joint - robot FLIPPED at ceiling -->
<joint name="world_to_base" type="fixed">
  <parent link="world"/>
  <child link="base_link"/>
  <!-- Robot at ceiling (Z=0.5m), flipped 180° around X-axis -->
  <!-- In flipped config: base is at top, pen tip points down -->
  <origin xyz="0 0 0.5" rpy="3.14159 0 0"/>
</joint>

<!-- ==================== CAMERA LINK ==================== -->
<link name="camera_link">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.01"/>
    <inertia ixx="0.00001" iyy="0.00001" izz="0.00001" ixy="0" iyz="0" ixz="0"/>
  </inertial>
  <!-- Camera body - GREEN for visibility -->
  <visual name="camera_body">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.04 0.03 0.03"/>
    </geometry>
    <material name="camera_green">
      <color rgba="0.0 1.0 0.0 1.0"/>
    </material>
  </visual>
</link>

<!-- Camera joint - looks toward vertical ArUco board -->
<joint name="camera_joint" type="fixed">
  <parent link="base_link"/>
  <child link="camera_link"/>
  <!-- Position at Y=0.15 (forward from base) -->
  <!-- Camera on FLIPPED base: More negative pitch = tilt UP (inverted) -->
  <!-- Markers at Y=-0.27, pitch -1.9 to frame all 4 -->
  <origin xyz="0 0.09 0" rpy="0 -2.3 -1.5708"/>
</joint>

<!-- ==================== ROBOT LINKS ==================== -->
<link name="base_link">
  <inertial>
    <origin xyz="-0.0036 -0.0039 0.0288" rpy="0 0 0"/>
    <mass value="1.685"/>
    <inertia ixx="0.003511" iyy="0.003304" izz="0.005332" ixy="1.1e-05" iyz="1.4e-05" ixz="-1.2e-05"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="steel_satin"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="Link1_1">
  <inertial>
    <origin xyz="0.00053 -0.01102 0.03535" rpy="0 0 0"/>
    <mass value="1.633"/>
    <inertia ixx="0.002276" iyy="0.002562" izz="0.002335" ixy="-2.3e-05" iyz="0.000395" ixz="3.1e-05"/>
  </inertial>
  <visual>
    <origin xyz="0.003394 0.003955 -0.068502" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/Link1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="steel_satin"/>
  </visual>
  <collision>
    <origin xyz="0.003394 0.003955 -0.068502" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/Link1_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="Link2_1">
  <inertial>
    <origin xyz="-0.04547 0.00081 0.06294" rpy="0 0 0"/>
    <mass value="1.730"/>
    <inertia ixx="0.003195" iyy="0.004256" izz="0.00182" ixy="-1.8e-05" iyz="-6.5e-05" ixz="-0.000207"/>
  </inertial>
  <visual>
    <origin xyz="-0.038427 0.023939 -0.122024" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/Link2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="steel_satin"/>
  </visual>
  <collision>
    <origin xyz="-0.038427 0.023939 -0.122024" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/Link2_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="Link3_1">
  <inertial>
    <origin xyz="0.03010 0.00305 0.03096" rpy="0 0 0"/>
    <mass value="0.907"/>
    <inertia ixx="0.001116" iyy="0.001117" izz="0.001148" ixy="-9e-06" iyz="-5.2e-05" ixz="-5.4e-05"/>
  </inertial>
  <visual>
    <origin xyz="0.037459 0.023946 -0.238747" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/Link3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="steel_satin"/>
  </visual>
  <collision>
    <origin xyz="0.037459 0.023946 -0.238747" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/Link3_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="Link4_1">
  <inertial>
    <origin xyz="-0.00117 -0.03133 0.03834" rpy="0 0 0"/>
    <mass value="1.190"/>
    <inertia ixx="0.001996" iyy="0.001998" izz="0.000833" ixy="9e-06" iyz="-5.3e-05" ixz="-5.3e-05"/>
  </inertial>
  <visual>
    <origin xyz="0.005255 -0.007589 -0.300911" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/Link4_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="steel_satin"/>
  </visual>
  <collision>
    <origin xyz="0.005255 -0.007589 -0.300911" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/Link4_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="Link5_1">
  <inertial>
    <origin xyz="0.02795 0.00598 0.02478" rpy="0 0 0"/>
    <mass value="0.743"/>
    <inertia ixx="0.000632" iyy="0.000871" izz="0.000826" ixy="-1.6e-05" iyz="-0.000137" ixz="-3.6e-05"/>
  </inertial>
  <visual>
    <origin xyz="0.037834 0.025511 -0.378125" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/Link5_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="steel_satin"/>
  </visual>
  <collision>
    <origin xyz="0.037834 0.025511 -0.378125" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/Link5_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="Link6_1">
  <inertial>
    <origin xyz="0.00002 -0.01576 -0.00172" rpy="0 0 0"/>
    <mass value="0.0796"/>
    <inertia ixx="1.2e-05" iyy="1.1e-05" izz="9e-06" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.006234 0.010211 -0.441925" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/Link6_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="steel_satin"/>
  </visual>
  <collision>
    <origin xyz="0.006234 0.010211 -0.441925" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/Link6_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="End-effector_1">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.00003"/>
    <inertia ixx="0.0" iyy="0.0" izz="0.0" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="0.006155 0.026302 -0.488369" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/End-effector_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="steel_satin"/>
  </visual>
  <collision>
    <origin xyz="0.006155 0.026302 -0.488369" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://visual_servoing/meshes/End-effector_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<!-- ==================== ROBOT JOINTS ==================== -->
<joint name="Joint 1" type="continuous">
  <origin xyz="-0.003394 -0.003955 0.068502" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="Link1_1"/>
  <axis xyz="0.0 0.0 1.0"/>
  <limit effort="100" velocity="100"/>
</joint>

<joint name="Joint 2" type="continuous">
  <origin xyz="0.041821 -0.019984 0.053522" rpy="0 0 0"/>
  <parent link="Link1_1"/>
  <child link="Link2_1"/>
  <axis xyz="-1.0 0.0 0.0"/>
  <limit effort="100" velocity="100"/>
</joint>

<joint name="Joint 3" type="continuous">
  <origin xyz="-0.075886 -7e-06 0.116723" rpy="0 0 0"/>
  <parent link="Link2_1"/>
  <child link="Link3_1"/>
  <axis xyz="-1.0 0.0 0.0"/>
  <limit effort="100" velocity="100"/>
</joint>

<joint name="Joint 4" type="continuous">
  <origin xyz="0.032204 0.031535 0.062164" rpy="0 0 0"/>
  <parent link="Link3_1"/>
  <child link="Link4_1"/>
  <axis xyz="0.0 -1.0 0.0"/>
  <limit effort="100" velocity="100"/>
</joint>

<joint name="Joint 5" type="continuous">
  <origin xyz="-0.032579 -0.0331 0.077214" rpy="0 0 0"/>
  <parent link="Link4_1"/>
  <child link="Link5_1"/>
  <axis xyz="-1.0 0.0 0.0"/>
  <limit effort="100" velocity="100"/>
</joint>

<joint name="Joint 6" type="continuous">
  <origin xyz="0.0316 0.0153 0.0638" rpy="0 0 0"/>
  <parent link="Link5_1"/>
  <child link="Link6_1"/>
  <axis xyz="0.0 -1.0 0.0"/>
  <limit effort="100" velocity="100"/>
</joint>

<joint name="Rigid 7" type="fixed">
  <origin xyz="7.9e-05 -0.016091 0.046444" rpy="0 0 0"/>
  <parent link="Link6_1"/>
  <child link="End-effector_1"/>
</joint>

<!-- ==================== GAZEBO SETTINGS ==================== -->
<!-- Disable gravity for all links -->
<gazebo reference="base_link"><gravity>false</gravity></gazebo>
<gazebo reference="Link1_1"><gravity>false</gravity></gazebo>
<gazebo reference="Link2_1"><gravity>false</gravity></gazebo>
<gazebo reference="Link3_1"><gravity>false</gravity></gazebo>
<gazebo reference="Link4_1"><gravity>false</gravity></gazebo>
<gazebo reference="Link5_1"><gravity>false</gravity></gazebo>
<gazebo reference="Link6_1"><gravity>false</gravity></gazebo>
<gazebo reference="End-effector_1"><gravity>false</gravity></gazebo>
<gazebo reference="camera_link"><gravity>false</gravity></gazebo>

<!-- Camera sensor plugin for Gazebo Fortress -->
<gazebo reference="camera_link">
  <sensor name="base_camera" type="camera">
    <always_on>true</always_on>
    <update_rate>30.0</update_rate>
    <visualize>true</visualize>
    <topic>/camera/image_raw</topic>
    <camera name="camera">
      <horizontal_fov>1.3962634</horizontal_fov>
      <image>
        <width>640</width>
        <height>480</height>
        <format>R8G8B8</format>
      </image>
      <clip>
        <near>0.05</near>  <!-- 5cm minimum -->
        <far>2.0</far>      <!-- 2m maximum (markers at ~0.4m) -->
      </clip>
    </camera>
    <!-- Gazebo Fortress camera plugin for publishing to ROS -->
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
  </sensor>
</gazebo>

<!-- ==================== ROS2 CONTROL ==================== -->
<ros2_control name="GazeboSystem" type="system">
  <hardware>
    <plugin>gz_ros2_control/GazeboSimSystem</plugin>
  </hardware>
  
  <joint name="Joint 1">
    <command_interface name="position">
      <param name="min">-3.14</param>
      <param name="max">3.14</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="Joint 2">
    <command_interface name="position">
      <param name="min">-3.14</param>
      <param name="max">3.14</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="Joint 3">
    <command_interface name="position">
      <param name="min">-3.14</param>
      <param name="max">3.14</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="Joint 4">
    <command_interface name="position">
      <param name="min">-1.57</param>
      <param name="max">1.57</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="Joint 5">
    <command_interface name="position">
      <param name="min">-3.14</param>
      <param name="max">3.14</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="Joint 6">
    <command_interface name="position">
      <param name="min">-3.14</param>
      <param name="max">3.14</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
</ros2_control>

<!-- Gazebo ros2_control plugin -->
<gazebo>
  <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
    <parameters>$(find visual_servoing)/config/controllers.yaml</parameters>
    <ros>
      <remapping>/controller_manager/robot_description:=/robot_description</remapping>
    </ros>
  </plugin>
</gazebo>

</robot>
